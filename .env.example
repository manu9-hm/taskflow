# Copy this file to .env and fill in your values
# NEVER commit the real .env file to git

# GitHub username or org (lowercase) — used by docker-compose.ghcr.yml image paths
CR_OWNER=your_github_username_lowercase

# PostgreSQL password (choose a strong random password)
DB_PASSWORD=your_strong_db_password_here

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_32_char_hex_secret_here

# Backend database URL (used when running locally without Docker)
DATABASE_URL=postgresql+asyncpg://taskflow:your_strong_db_password_here@localhost:5432/taskflow

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Optional: OpenAI API key for embeddings (falls back to local model if not set)
OPENAI_API_KEY=
